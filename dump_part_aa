def _timed_invoke(self, *args, **kwargs):
    t0 = time.time()
    result = _orig_invoke(self, *args, **kwargs)
    elapsed = time.time() - t0
    name = getattr(result, 'name', 'unknown')
    call_times.append((name, elapsed))
