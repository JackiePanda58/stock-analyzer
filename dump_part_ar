  if (!providerId) {
    console.log('⚠️ 厂家ID为空')
    return []
  }
  const models = llmConfigs.value.filter(config => {
    console.log(`检查模型: ${config.model_name}, provider: ${config.provider}, enabled: ${config.enabled}`)
    return config.provider === providerId && config.enabled
